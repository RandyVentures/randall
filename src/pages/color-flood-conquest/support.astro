---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Color Flood Conquest Support"
      description="Support information for Color Flood Conquest."
    />
  </head>
  <body>
    <Header />
    <main>
      <h1>Support - Color Flood Conquest</h1>
      <p>
        Thanks for playing Color Flood Conquest. If you need help with gameplay,
        purchases, ads, or technical issues, use the contact details below.
      </p>

      <h2>Contact</h2>
      <p>Email: <a href="mailto:rltorres26@gmail.com">rltorres26@gmail.com</a></p>

      <h2>Common Topics</h2>
      <ul>
        <li>Restore Purchase: Open Settings and tap "Restore Purchases".</li>
        <li>Ads still visible after purchase: Restore purchases, then relaunch the app.</li>
        <li>Tracking permission: Open Settings in the app and request tracking permission if it has not been asked yet.</li>
        <li>Gameplay issue: Share your device model, iOS version, and a screenshot if possible.</li>
      </ul>

      <p>
        Privacy details are available at
        <a href={import.meta.env.BASE_URL + '/color-flood-conquest/privacy'}>
          Color Flood Conquest Privacy Policy
        </a>.
      </p>
    </main>
    <Footer />
  </body>
</html>
