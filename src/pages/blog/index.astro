---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const allTags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (path: string) => `${base}${path}`;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts — ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1 class="page-title">The log</h1>
				<p class="page-desc">
					Weekly notes on shipping apps, work, rentals, family, and faith in South Texas.
				</p>
				<div class="tag-filter" role="group" aria-label="Filter posts by topic">
					<button type="button" data-filter="all" aria-pressed="true">All ({posts.length})</button>
					{allTags.map((tag) => (
						<button type="button" data-filter={tag} aria-pressed="false">
							{tag} ({posts.filter((p) => p.data.tags.includes(tag)).length})
						</button>
					))}
				</div>
				<ul class="post-list" id="post-list">
					{posts.map((post) => (
						<li data-tags={post.data.tags.join(' ')}>
							<div class="post-row">
								<div class="post-row-text">
									<div class="post-meta">
										<FormattedDate date={post.data.pubDate} />
										{post.data.tags.map((tag) => (
											<span class="tag-chip" data-tag={tag}>{tag}</span>
										))}
									</div>
									<h2 class="post-title">
										<a class="post-title-link" href={withBase(`/blog/${post.id}/`)}>
											{post.data.title}
										</a>
									</h2>
									{post.data.description && <p class="post-summary">{post.data.description}</p>}
								</div>
								{post.data.heroImage ? (
									<a class="post-thumb" href={withBase(`/blog/${post.id}/`)} tabindex="-1" aria-hidden="true">
										<Image width={180} height={130} src={post.data.heroImage} alt="" />
									</a>
								) : (
									<span class="post-thumb" aria-hidden="true">
										<span class="post-thumb-fallback">{post.data.title.charAt(0)}</span>
									</span>
								)}
							</div>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
		<script>
			const buttons = document.querySelectorAll<HTMLButtonElement>('.tag-filter button');
			const items = document.querySelectorAll<HTMLLIElement>('#post-list > li');
			buttons.forEach((button) => {
				button.addEventListener('click', () => {
					const filter = button.dataset.filter;
					buttons.forEach((b) => b.setAttribute('aria-pressed', String(b === button)));
					items.forEach((item) => {
						const tags = (item.dataset.tags || '').split(' ');
						item.style.display = filter === 'all' || tags.includes(filter!) ? '' : 'none';
					});
				});
			});
		</script>
	</body>
</html>
