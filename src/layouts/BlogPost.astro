---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & { readTime?: number };

const { title, description, pubDate, updatedDate, heroImage, readTime, tags = [] } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			main {
				width: 780px;
				max-width: calc(100% - 2.5em);
			}
			.post-hero {
				background: var(--tile);
				border: 1px solid var(--line);
				border-radius: var(--radius-tile);
				padding: 2.2rem 2.4rem;
				display: grid;
				gap: 1rem;
				margin-bottom: 14px;
				animation: hero-rise 0.5s ease both;
			}
			.post-hero h1 {
				margin: 0;
				font-size: clamp(1.7rem, 3.6vw, 2.5rem);
			}
			.meta-row {
				display: flex;
				flex-wrap: wrap;
				gap: 0.55rem 0.9rem;
				align-items: center;
			}
			.date {
				color: var(--ink-muted);
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-weight: 600;
				font-size: 0.78rem;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.85rem;
				color: var(--ink-muted);
			}
			.deck {
				font-size: 1.1rem;
				color: var(--ink-muted);
				margin: 0;
			}
			.hero-image {
				margin: 0.4rem 0 0;
			}
			.hero-image img {
				display: block;
				width: 100%;
				height: auto;
				border-radius: 12px;
			}
			.post-body {
				background: var(--tile);
				border: 1px solid var(--line);
				border-radius: var(--radius-tile);
				padding: 2.2rem 2.4rem;
				margin-bottom: 3rem;
			}
			@media (max-width: 720px) {
				.post-hero,
				.post-body {
					padding: 1.3rem 1.2rem;
				}
			}
			@keyframes hero-rise {
				from {
					opacity: 0;
					transform: translateY(12px);
				}
				to {
					opacity: 1;
					transform: translateY(0);
				}
			}
			@media (prefers-reduced-motion: reduce) {
				.post-hero {
					animation: none;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<a class="back-link" href={`${base}/blog`}>← All posts</a>
			<article>
				<section class="post-hero">
					<div class="meta-row">
						<span class="date"><FormattedDate date={pubDate} /></span>
						{readTime && <span class="read-time">{readTime} min read</span>}
						{tags.map((tag) => (
							<span class="tag-chip" data-tag={tag}>{tag}</span>
						))}
						{
							updatedDate && (
								<span class="last-updated-on">
									Updated <FormattedDate date={updatedDate} />
								</span>
							)
						}
					</div>
					<h1>{title}</h1>
					{description && <p class="deck">{description}</p>}
					{heroImage && (
						<div class="hero-image">
							<Image width={1020} height={510} src={heroImage} alt={title + ' - Hero Image'} />
						</div>
					)}
				</section>
				<section class="post-body">
					<div class="prose">
						<slot />
					</div>
				</section>
			</article>
		</main>
		<Footer />
	</body>
</html>
